{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Frontend: Vite Dev",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "autoAttachChildProcesses": false,
      "skipFiles": ["<node_internals>/**", "${workspaceFolder}/frontend/node_modules/**"]
    },
    {
      "name": "Backend: Uvicorn",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": ["backend.app:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/Scripts/python.exe",
      "jinja": true
    }
  ],
  "compounds": [
    {
      "name": "Full Stack",
      "configurations": ["Backend: Uvicorn", "Frontend: Vite Dev"]
    }
  ]
}
